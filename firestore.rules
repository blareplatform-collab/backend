rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Signals: any authenticated user can read, only backend (unauthenticated server) writes
    match /signals/{signalId} {
      allow read: if request.auth != null;
      allow write: if false; // backend writes via Admin SDK (bypasses rules)
    }

    // Trades: users can only see their own trades
    match /trades/{tradeId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow write: if false; // backend only
    }

    // Analytics: users can only read their own analytics
    match /analytics/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // backend only
    }
  }
}
